<!DOCTYPE html>
<% const p = t.lovart_ai_video_page || {}; %>
<% const breadcrumbItems = [{ name: t.nav.home, href: link('/') }, { name: p.seo.title.split('|')[0].trim(), href: canonicalUrl }]; %>
<html lang="<%= lang %>" class="scroll-smooth">
<head>
    <%- include('partials/head', { pageSeo: p.seo }) %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= p.seo.title %></title>
    <meta name="description" content="<%= p.seo.description %>">
    <link rel="canonical" href="<%= canonicalUrl %>">
    <%- include('partials/hreflang') %>
    <link rel="stylesheet" href="/styles.css">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3083296102953963" crossorigin="anonymous"></script>
    <%- include('partials/analytics') %>
    <%- include('partials/schema-breadcrumb', { breadcrumbItems }) %>
    <%- include('partials/schema-faq', { faqItems: p.faq && p.faq.items }) %>

    <style>
        .section-animate { opacity: 0; transform: translateY(30px); transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
        .section-animate.is-visible { opacity: 1; transform: translateY(0); }
    </style>
</head>
<body class="bg-neutral-light text-neutral-dark antialiased">
    <%- include('partials/header') %>
    <%- include('partials/breadcrumb', { breadcrumbItems }) %>
    <main>
        <!-- Hero -->
        <section class="bg-gradient-to-br from-primary to-secondary text-white py-20 md:py-28">
            <div class="container mx-auto px-6 text-center">
                <h1 class="text-4xl md:text-5xl font-bold mb-4"><%= p.hero.title %></h1>
                <p class="text-lg md:text-xl mb-8 max-w-2xl mx-auto"><%= p.hero.desc %></p>
                <a href="https://lovart.ai" target="_blank" rel="noopener noreferrer"
                    class="bg-white text-primary px-8 py-3 rounded-md font-semibold hover:bg-neutral-light transition-colors">
                    <%= p.cta.button %>
                </a>
            </div>
        </section>

        <!-- Disclaimer -->
        <div class="bg-amber-50 border-b border-amber-200 py-2 text-center text-xs text-amber-700">
            <%= p.disclaimer %>
        </div>

        <!-- Overview -->
        <% if (p.overview && p.overview.cards) { %>
        <section class="py-14 md:py-20 bg-white section-animate">
            <div class="container mx-auto px-6">
                <div class="max-w-4xl mx-auto text-center mb-10">
                    <h2 class="text-2xl md:text-3xl font-bold text-neutral-dark mb-4"><%= p.overview.title %></h2>
                    <p class="text-neutral text-lg"><%= p.overview.desc %></p>
                </div>
                <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <% p.overview.cards.forEach(function(card) { %>
                    <article class="bg-neutral-light rounded-xl p-6 border border-neutral-light/50">
                        <h3 class="text-lg font-semibold text-neutral-dark mb-3"><%= card.title %></h3>
                        <p class="text-neutral"><%= card.desc %></p>
                    </article>
                    <% }); %>
                </div>
            </div>
        </section>
        <% } %>

        <!-- How It Works -->
        <% if (p.how_it_works && p.how_it_works.steps) { %>
        <section class="py-16 md:py-24 bg-neutral-light section-animate">
            <div class="container mx-auto px-6">
                <div class="max-w-4xl mx-auto text-center mb-12">
                    <h2 class="text-2xl md:text-3xl font-bold text-neutral-dark mb-4"><%= p.how_it_works.title %></h2>
                </div>
                <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <% p.how_it_works.steps.forEach(function(step) { %>
                    <article class="bg-white rounded-xl p-6 border border-neutral-light/60 shadow-sm">
                        <p class="text-xs uppercase tracking-wide text-primary font-semibold mb-3"><%= step.label %></p>
                        <h3 class="text-lg font-semibold text-neutral-dark mb-2"><%= step.title %></h3>
                        <p class="text-neutral text-sm leading-6"><%= step.desc %></p>
                    </article>
                    <% }); %>
                </div>
            </div>
        </section>
        <% } %>

        <!-- Use Cases -->
        <% if (p.use_cases && p.use_cases.items) { %>
        <section class="py-16 md:py-20 bg-white section-animate">
            <div class="container mx-auto px-6">
                <h2 class="text-2xl md:text-3xl font-bold text-neutral-dark mb-10 text-center"><%= p.use_cases.title %></h2>
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <% p.use_cases.items.forEach(function(item) { %>
                    <article class="bg-neutral-light rounded-xl p-6">
                        <h3 class="text-lg font-semibold text-neutral-dark mb-2"><%= item.title %></h3>
                        <p class="text-neutral text-sm"><%= item.desc %></p>
                    </article>
                    <% }); %>
                </div>
            </div>
        </section>
        <% } %>

        <!-- AdSense -->
        <div class="container mx-auto px-6 py-6 text-center">
            <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-3083296102953963" data-ad-slot="2395486240" data-ad-format="auto" data-full-width-responsive="true"></ins>
            <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>

        <!-- FAQ -->
        <% if (p.faq && p.faq.items) { %>
        <section class="py-16 md:py-20 bg-neutral-light section-animate">
            <div class="container mx-auto px-6 max-w-4xl">
                <h2 class="text-2xl md:text-3xl font-bold text-neutral-dark mb-8 text-center"><%= p.faq.title %></h2>
                <div class="space-y-6">
                    <% p.faq.items.forEach(function(item) { %>
                    <article class="border border-neutral-light/60 rounded-lg p-5 bg-white">
                        <h3 class="text-lg font-semibold text-neutral-dark mb-2"><%= item.q %></h3>
                        <p class="text-neutral"><%= item.a %></p>
                    </article>
                    <% }); %>
                </div>
            </div>
        </section>
        <% } %>

        <!-- CTA -->
        <section class="py-16 md:py-24 bg-gradient-to-br from-primary to-secondary text-white section-animate">
            <div class="container mx-auto px-6 text-center">
                <h2 class="text-3xl md:text-4xl font-bold mb-6"><%= p.cta.title %></h2>
                <p class="text-lg mb-8 max-w-xl mx-auto opacity-90"><%= p.cta.desc %></p>
                <a href="https://lovart.ai" target="_blank" rel="noopener noreferrer"
                    class="bg-white text-primary px-10 py-4 rounded-md hover:bg-neutral-light transition-colors text-lg font-medium">
                    <%= p.cta.button %>
                </a>
            </div>
        </section>

        <!-- Related Resources -->
        <% if (p.related && p.related.items) { %>
        <section class="py-12 bg-white">
            <div class="container mx-auto px-6 max-w-6xl">
                <h2 class="text-2xl font-bold mb-8 text-center"><%= p.related.title %></h2>
                <div class="grid md:grid-cols-4 gap-6">
                    <% const relatedLinks = ['lovart-ai-logo-design', 'lovart-gpt-4o-image', 'lovart-3d-image-generator', 'lovart-design-features']; %>
                    <% p.related.items.forEach(function(item, i) { %>
                    <a href="<%= link(relatedLinks[i]) %>"
                        class="block p-5 rounded-xl border border-neutral-light/30 hover:shadow-md hover:border-primary/30 transition-all text-center">
                        <h3 class="font-semibold mb-1"><%= item.title %></h3>
                        <p class="text-xs text-neutral mb-2"><%= item.desc %></p>
                        <span class="text-primary text-sm font-medium"><%= item.link_text %></span>
                    </a>
                    <% }); %>
                </div>
            </div>
        </section>
        <% } %>
    </main>
    <%- include('partials/footer') %>
    <script>
        document.getElementById('currentYear').textContent = new Date().getFullYear();
        const mobileMenuButton = document.getElementById('mobile-menu-button');
        const mobileMenu = document.getElementById('mobile-menu');
        if (mobileMenuButton && mobileMenu) {
            mobileMenuButton.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
        }
        const sections = document.querySelectorAll('.section-animate');
        if ('IntersectionObserver' in window) {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => { if (entry.isIntersecting) { entry.target.classList.add('is-visible'); observer.unobserve(entry.target); } });
            }, { threshold: 0.1 });
            sections.forEach(section => observer.observe(section));
        } else {
            sections.forEach(section => section.classList.add('is-visible'));
        }
    </script>
</body>
</html>
