<%
const supportPages = ((t.support_cluster || {}).pages || {});
const normalizePath = (value) => {
    if (typeof value !== 'string') {
        return '';
    }

    let normalizedValue = value.trim();
    if (normalizedValue.startsWith('/')) {
        normalizedValue = normalizedValue.slice(1);
    }
    if (normalizedValue.endsWith('/')) {
        normalizedValue = normalizedValue.slice(0, -1);
    }

    return normalizedValue;
};
const relatedMetaByPath = {
    'lovart-logo': t.lovart_logo_page && t.lovart_logo_page.seo,
    'lovart-design-features': t.features_page && t.features_page.seo,
    'what-is-lovart': t.what_is_lovart_page && t.what_is_lovart_page.seo,
    'lovart-free': t.lovart_free_page && t.lovart_free_page.seo,
    'lovart-pricing': t.pricing_page && t.pricing_page.seo,
    'lovart-china': t.lovart_china_page && t.lovart_china_page.seo,
    'lovart-brand-kit': t.lovart_brand_kit_page && t.lovart_brand_kit_page.seo,
    'lovart-ai-code': t.lovart_ai_code_page && t.lovart_ai_code_page.seo,
    'lovart-promo-code': t.lovart_promo_page && t.lovart_promo_page.seo,
    'lovart-apk': t.lovart_apk_page && t.lovart_apk_page.seo,
    'lovart-terms-of-use-guide': supportPages.terms_of_use_guide && supportPages.terms_of_use_guide.seo,
    'lovart-customer-support': supportPages.customer_support && supportPages.customer_support.seo,
    'lovart-refund-guide': supportPages.refund_guide && supportPages.refund_guide.seo,
    'lovart-account-deletion-guide': supportPages.account_deletion_guide && supportPages.account_deletion_guide.seo,
    'lovart-support-contact': supportPages.support_contact && supportPages.support_contact.seo
};
const normalizedRelatedItems = (Array.isArray(relatedItems) ? relatedItems : [])
    .map((item) => {
        const rawPath = typeof item === 'string' ? item : item && item.path;
        const pathKey = normalizePath(rawPath);
        const pageMeta = relatedMetaByPath[pathKey] || {};

        return {
            path: pathKey,
            title: (item && item.title) || pageMeta.title || pathKey,
            desc: (item && item.desc) || pageMeta.description || ''
        };
    })
    .filter((item) => item.path);
const sectionTitle = (typeof relatedTitle === 'string' && relatedTitle.trim())
    ? relatedTitle.trim()
    : ((t.resources_section && t.resources_section.title) || 'Related Resources');
const sectionDescription = (typeof relatedDescription === 'string' && relatedDescription.trim())
    ? relatedDescription.trim()
    : '';
%>
<% if (normalizedRelatedItems.length) { %>
<section id="related-resources" class="py-14 bg-white border-y border-neutral/10">
    <div class="container mx-auto px-4 md:px-6 max-w-5xl">
        <div class="max-w-3xl mb-8">
            <h2 class="text-2xl md:text-3xl font-bold text-neutral-dark mb-3"><%= sectionTitle %></h2>
            <% if (sectionDescription) { %>
                <p class="text-neutral leading-relaxed"><%= sectionDescription %></p>
            <% } %>
        </div>
        <div class="grid gap-4 md:grid-cols-3">
            <% normalizedRelatedItems.forEach(function(item) { %>
                <a href="<%= link(item.path) %>"
                    class="group bg-neutral-light border border-neutral/10 rounded-2xl p-6 hover:border-primary/30 hover:shadow-md transition-all">
                    <h3 class="text-lg font-semibold text-neutral-dark mb-2 group-hover:text-primary transition-colors">
                        <%= item.title %>
                    </h3>
                    <p class="text-sm text-neutral leading-relaxed mb-4"><%= item.desc %></p>
                    <span class="text-sm font-semibold text-primary">Explore →</span>
                </a>
            <% }) %>
        </div>
    </div>
</section>
<% } %>
