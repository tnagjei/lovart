<!DOCTYPE html>
<%
const breadcrumbItems = [{ name: t.nav.home, href: link('/') }, { name: t.breadcrumb.pages.lovart_ai_code, href: canonicalUrl }];
const page = t.lovart_ai_code_page;
%>
<html lang="<%= lang %>" class="scroll-smooth">

<head>
    <%- include('partials/head') %>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>
            <%= page.seo.title %>
        </title>
        <meta name="description" content="<%= page.seo.description %>">
        <meta name="keywords" content="<%= page.seo.keywords %>">
        <link rel="canonical" href="<%= canonicalUrl %>">
        <%- include('partials/hreflang') %>
            <link rel="stylesheet" href="/styles.css">
            <link rel="icon" href="/favicon.ico" type="image/x-icon">
            <script async
                src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3083296102953963"
                crossorigin="anonymous"></script>
            <%- include('partials/analytics') %>
                <%- include('partials/schema-breadcrumb', { breadcrumbItems }) %>

</head>

<body class="bg-neutral-light text-neutral-dark antialiased">

    <%- include('partials/header') %>

        <%- include('partials/breadcrumb', { breadcrumbItems }) %>
            <main>
                <section class="py-16 md:py-24 section-animate">
                    <div class="container mx-auto px-6">
                        <h1 class="text-3xl md:text-4xl font-bold text-center text-neutral-dark mb-6 animate-fade-in-up">
                            <%= page.hero.title %>
                        </h1>
                        <p class="text-center text-neutral text-lg max-w-3xl mx-auto mb-8 animate-fade-in-up"
                            style="animation-delay: 0.2s;">
                            <%= page.hero.description %>
                        </p>

                        <% if (page.hero.badges && page.hero.badges.length) { %>
                            <div class="flex flex-wrap justify-center gap-3 mb-12 animate-fade-in-up" style="animation-delay: 0.3s;">
                                <% page.hero.badges.forEach(function(badge) { %>
                                    <span class="px-3 py-1 bg-white rounded-full border border-neutral-light text-sm text-neutral-dark font-medium">
                                        <%= badge %>
                                    </span>
                                    <% }) %>
                            </div>
                            <% } %>

                                <div class="space-y-12">
                                    <div class="animate-fade-in-up" style="animation-delay: 0.4s;">
                                        <h2 class="text-2xl md:text-3xl font-semibold text-neutral-dark mb-4">
                                            <%= page.ai_core.title %>
                                        </h2>
                                        <p class="text-neutral mb-3">
                                            <%= page.ai_core.p1 %>
                                        </p>
                                        <p class="text-neutral mb-3">
                                            <%= page.ai_core.p2 %>
                                        </p>
                                        <p class="text-neutral">
                                            <%= page.ai_core.p3 %>
                                        </p>
                                    </div>

                                    <div class="animate-fade-in-up" style="animation-delay: 0.6s;">
                                        <h2 class="text-2xl md:text-3xl font-semibold text-neutral-dark mb-4">
                                            <%= page.api_integration.title %>
                                        </h2>
                                        <p class="text-neutral mb-3">
                                            <%= page.api_integration.p1 %>
                                        </p>
                                        <p class="text-neutral mb-3">
                                            <%= page.api_integration.p_endpoints %>
                                        </p>
                                        <ul class="list-disc list-inside text-neutral space-y-2 mb-4">
                                            <% page.api_integration.list.forEach(function(item) { %>
                                                <li><strong>
                                                        <%= item.title %>
                                                    </strong>
                                                    <%= item.desc %>
                                                </li>
                                                <% }); %>
                                        </ul>
                                        <p class="text-neutral mb-5">
                                            <%= page.api_integration.p_stay_tuned %>
                                        </p>

                                        <% if (page.api_integration.status_items && page.api_integration.status_items.length) { %>
                                            <div class="bg-white border border-neutral-light/50 rounded-lg p-5 mb-5">
                                                <h3 class="text-lg font-semibold text-neutral-dark mb-3">
                                                    <%= page.api_integration.status_title %>
                                                </h3>
                                                <ul class="space-y-2">
                                                    <% page.api_integration.status_items.forEach(function(item) { %>
                                                        <li class="flex items-center justify-between gap-4 text-sm">
                                                            <span class="text-neutral-dark">
                                                                <%= item.name %>
                                                            </span>
                                                            <span class="px-2 py-1 rounded-full bg-neutral-light text-neutral-dark font-medium whitespace-nowrap">
                                                                <%= item.status %>
                                                            </span>
                                                        </li>
                                                        <% }); %>
                                                </ul>
                                            </div>
                                            <% } %>

                                                <div class="flex flex-wrap gap-3">
                                                    <a href="<%= link('lovart-api') %>"
                                                        class="bg-primary text-white px-6 py-3 rounded-md hover:bg-primary-dark transition-colors text-sm font-medium">
                                                        <%= page.api_integration.docs_link_text %>
                                                    </a>
                                                    <a href="mailto:sales@lovart.info?subject=Lovart%20API%20Access%20Request"
                                                        class="bg-white border border-neutral-light text-neutral-dark px-6 py-3 rounded-md hover:bg-neutral-light transition-colors text-sm font-medium">
                                                        <%= page.api_integration.access_link_text %>
                                                    </a>
                                                </div>
                                    </div>

                                    <div class="animate-fade-in-up" style="animation-delay: 0.7s;">
                                        <h2 class="text-2xl md:text-3xl font-semibold text-neutral-dark mb-4">
                                            <%= page.use_cases.title %>
                                        </h2>
                                        <p class="text-neutral mb-3">
                                            <%= page.use_cases.desc %>
                                        </p>
                                        <ul class="list-disc list-inside text-neutral space-y-3 mb-3">
                                            <% page.use_cases.list.forEach(function(item) { %>
                                                <li><strong>
                                                        <%= item.title %>
                                                    </strong>
                                                    <%= item.desc %>
                                                </li>
                                                <% }); %>
                                        </ul>
                                        <p class="text-neutral">
                                            <%= page.use_cases.conclusion %>
                                        </p>
                                    </div>

                                    <div class="animate-fade-in-up" style="animation-delay: 0.8s;">
                                        <h2 class="text-2xl md:text-3xl font-semibold text-neutral-dark mb-4">
                                            <%= page.resources.title %>
                                        </h2>
                                        <p class="text-neutral mb-3">
                                            <%= page.resources.desc %>
                                        </p>
                                        <ul class="list-disc list-inside text-neutral space-y-2 mb-3">
                                            <% page.resources.list.forEach(function(item) { %>
                                                <li><strong>
                                                        <%= item.title %>
                                                    </strong>
                                                    <%= item.desc %>
                                                </li>
                                                <% }); %>
                                        </ul>
                                        <p class="text-neutral">
                                            <%= page.resources.objective %>
                                        </p>
                                    </div>

                                    <div class="text-center pt-8 animate-fade-in-up" style="animation-delay: 1s;">
                                        <h3 class="text-xl font-semibold text-neutral-dark mb-3">
                                            <%= page.cta.title %>
                                        </h3>
                                        <p class="text-neutral mb-6 max-w-xl mx-auto">
                                            <%= page.cta.desc %>
                                        </p>
                                        <div class="flex flex-wrap justify-center gap-4">
                                            <a href="<%= link('lovart-api') %>"
                                                class="bg-primary text-white px-8 py-3 rounded-md hover:bg-primary-dark transition-colors text-lg font-medium">
                                                <%= page.cta.primary_button %>
                                            </a>
                                            <a href="mailto:sales@lovart.info?subject=Lovart%20API%20Access%20Request"
                                                class="bg-white border border-neutral-light text-neutral-dark px-8 py-3 rounded-md hover:bg-neutral-light transition-colors text-lg font-medium">
                                                <%= page.cta.secondary_button %>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                    </div>
                </section>

                <!-- ★ Developer Topics Module (Phase 1 Batch 1) — DO NOT REMOVE -->
                <% if (lang === 'en' || lang === 'zh') { %>
                <section class="py-14 bg-slate-900 text-white">
                    <div class="container mx-auto px-6 max-w-5xl">
                        <div class="text-center mb-10">
                            <span class="inline-flex items-center gap-2 bg-indigo-500/20 border border-indigo-400/30 rounded-full px-4 py-1 text-sm text-indigo-300 mb-4">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
                                Developer Topics
                            </span>
                            <h2 class="text-2xl md:text-3xl font-bold text-white"><%= lang === 'zh' ? '探索 Lovart 开发者资源' : 'Explore Lovart Developer Resources' %></h2>
                            <p class="text-slate-400 mt-3 max-w-2xl mx-auto"><%= lang === 'zh' ? '下方每个页面针对一个特定的开发者疑问。我们已明确区分哪些是官方确认的信息，哪些是我们无法核实的说法。' : 'Each page below addresses a specific developer question. We clearly separate what is officially confirmed from what we could not verify.' %></p>
                        </div>
                        <div class="grid sm:grid-cols-2 gap-5">
                            <a href="<%= link('lovart-api-key') %>"
                               class="group flex items-start gap-4 p-5 bg-white/5 border border-white/10 rounded-xl hover:bg-indigo-500/10 hover:border-indigo-400/40 transition-all">
                                <div class="w-10 h-10 bg-indigo-600 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
                                </div>
                                <div>
                                    <p class="font-bold text-white group-hover:text-indigo-300 transition-colors"><%= lang === 'zh' ? 'Lovart API 密钥' : 'Lovart API Key' %></p>
                                    <p class="text-sm text-slate-400 mt-1"><%= lang === 'zh' ? '是否存在公开 API 密钥？可在何处申请及预期是什么。' : 'Is there a public API key? Where to apply and what to expect.' %></p>
                                    <span class="text-xs text-indigo-400 mt-2 inline-block"><%= lang === 'zh' ? '阅读更多 →' : 'Read more →' %></span>
                                </div>
                            </a>
                            <a href="<%= link('lovart-api-documentation') %>"
                               class="group flex items-start gap-4 p-5 bg-white/5 border border-white/10 rounded-xl hover:bg-indigo-500/10 hover:border-indigo-400/40 transition-all">
                                <div class="w-10 h-10 bg-purple-600 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                </div>
                                <div>
                                    <p class="font-bold text-white group-hover:text-purple-300 transition-colors"><%= lang === 'zh' ? 'API 文档' : 'API Documentation' %></p>
                                    <p class="text-sm text-slate-400 mt-1"><%= lang === 'zh' ? '目前存在哪些官方开发者资源，以及哪些内容暂时无法核实。' : 'Which official developer resources exist and what we could not verify.' %></p>
                                    <span class="text-xs text-purple-400 mt-2 inline-block"><%= lang === 'zh' ? '阅读更多 →' : 'Read more →' %></span>
                                </div>
                            </a>
                            <a href="<%= link('lovart-api-pricing') %>"
                               class="group flex items-start gap-4 p-5 bg-white/5 border border-white/10 rounded-xl hover:bg-indigo-500/10 hover:border-indigo-400/40 transition-all">
                                <div class="w-10 h-10 bg-emerald-600 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                </div>
                                <div>
                                    <p class="font-bold text-white group-hover:text-emerald-300 transition-colors"><%= lang === 'zh' ? 'API 定价' : 'API Pricing' %></p>
                                    <p class="text-sm text-slate-400 mt-1"><%= lang === 'zh' ? 'API 是否有独立的定价层级？哪些套餐包含 API 访问权限？' : 'Is there a separate API pricing tier? What plans include API access?' %></p>
                                    <span class="text-xs text-emerald-400 mt-2 inline-block"><%= lang === 'zh' ? '阅读更多 →' : 'Read more →' %></span>
                                </div>
                            </a>
                            <a href="<%= link('lovart-developer-options') %>"
                               class="group flex items-start gap-4 p-5 bg-white/5 border border-white/10 rounded-xl hover:bg-indigo-500/10 hover:border-indigo-400/40 transition-all">
                                <div class="w-10 h-10 bg-orange-600 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                </div>
                                <div>
                                    <p class="font-bold text-white group-hover:text-orange-300 transition-colors"><%= lang === 'zh' ? '开发者替代方案' : 'Developer Options' %></p>
                                    <p class="text-sm text-slate-400 mt-1"><%= lang === 'zh' ? '如果未提供公开 API，目前还有哪些可行的集成方案？' : 'If public API isn\'t available, what integration alternatives exist right now?' %></p>
                                    <span class="text-xs text-orange-400 mt-2 inline-block"><%= lang === 'zh' ? '阅读更多 →' : 'Read more →' %></span>
                                </div>
                            </a>
                        </div>
                        <p class="text-center text-xs text-slate-500 mt-8 mb-6"><%= lang === 'zh' ? 'lovart.info 属于独立资讯站，与 Lovart 无关。本站所有开发者相关内容均已明确区分已确认的事实与无法核实的信息。' : 'lovart.info is an independent resource. We are not affiliated with Lovart. All developer information clearly distinguishes confirmed facts from unverified claims.' %></p>
                        
                        <%- include('partials/commercial-cta', { context: 'ai_code' }) %>
                    </div>
                </section>
                <% } %>
                <!-- ★ End Developer Topics Module -->

                <section class="py-12 bg-white">
                    <div class="container mx-auto px-6 max-w-6xl">
                        <h2 class="text-2xl font-bold mb-8 text-center">
                            <%= page.related.title %>
                        </h2>
                        <div class="grid md:grid-cols-3 gap-6">
                            <a href="<%= link('lovart-api') %>"
                                class="block p-5 rounded-xl border border-neutral-light/30 hover:shadow-md hover:border-primary/30 transition-all text-center">
                                <h3 class="font-semibold mb-1">
                                    <%= page.related.items[0].title %>
                                </h3>
                                <p class="text-xs text-neutral mb-2">
                                    <%= page.related.items[0].desc %>
                                </p>
                                <span class="text-primary text-sm font-medium">
                                    <%= page.related.items[0].link_text %>
                                </span>
                            </a>
                            <a href="<%= link('lovart-pricing') %>"
                                class="block p-5 rounded-xl border border-neutral-light/30 hover:shadow-md hover:border-primary/30 transition-all text-center">
                                <h3 class="font-semibold mb-1">
                                    <%= page.related.items[1].title %>
                                </h3>
                                <p class="text-xs text-neutral mb-2">
                                    <%= page.related.items[1].desc %>
                                </p>
                                <span class="text-primary text-sm font-medium">
                                    <%= page.related.items[1].link_text %>
                                </span>
                            </a>
                            <a href="<%= link('lovart-free') %>"
                                class="block p-5 rounded-xl border border-neutral-light/30 hover:shadow-md hover:border-primary/30 transition-all text-center">
                                <h3 class="font-semibold mb-1">
                                    <%= page.related.items[2].title %>
                                </h3>
                                <p class="text-xs text-neutral mb-2">
                                    <%= page.related.items[2].desc %>
                                </p>
                                <span class="text-primary text-sm font-medium">
                                    <%= page.related.items[2].link_text %>
                                </span>
                            </a>
                        </div>
                    </div>
                </section>
            </main>

            <%- include('partials/footer') %>

                <script>
                    document.addEventListener('DOMContentLoaded', () => {
                        const currentYearSpan = document.getElementById('currentYear');
                        if (currentYearSpan) currentYearSpan.textContent = new Date().getFullYear();

                        const mobileMenuButton = document.getElementById('mobile-menu-button');
                        const mobileMenu = document.getElementById('mobile-menu');
                        if (mobileMenuButton && mobileMenu) {
                            mobileMenuButton.addEventListener('click', () => {
                                mobileMenu.classList.toggle('hidden');
                            });
                        }

                        const sections = document.querySelectorAll('.section-animate');
                        const observer = new IntersectionObserver((entries) => {
                            entries.forEach(entry => {
                                if (entry.isIntersecting) {
                                    entry.target.classList.add('is-visible');
                                    observer.unobserve(entry.target);
                                }
                            });
                        }, { threshold: 0.1 });

                        sections.forEach(section => {
                            observer.observe(section);
                        });
                    });
                </script>
</body>

</html>
