<!DOCTYPE html>
<% const page = t.lovart_api_pricing_page; %>
<html lang="<%= lang %>" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('partials/head') %>
    <title><%= page.seo.title %></title>
    <meta name="description" content="<%= page.seo.description %>">
    <meta name="keywords" content="<%= page.seo.keywords %>">
    <link rel="canonical" href="<%= canonicalUrl %>">
    <%- include('partials/hreflang') %>

    <link rel="stylesheet" href="/styles.css">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3083296102953963" crossorigin="anonymous"></script>
    <%- include('partials/analytics') %>
</head>
<body class="bg-gray-50 text-gray-900 antialiased">
<%- include('partials/header') %>

<main class="bg-gray-50 min-h-screen">

  <!-- Hero -->
  <section class="bg-gradient-to-br from-slate-900 to-indigo-900 text-white py-16 px-6">
    <div class="container mx-auto max-w-4xl">
      <div class="inline-flex items-center gap-2 bg-indigo-500/20 border border-indigo-400/30 rounded-full px-4 py-1 text-sm text-indigo-300 mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
        Developer Resource
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold mb-4 leading-tight"><%=  page.hero.title %></h1>
      <p class="text-lg text-slate-300 max-w-2xl"><%=  page.hero.desc %></p>
    </div>
  </section>

  <div class="container mx-auto max-w-4xl px-6 py-12 space-y-10">

    <!-- Quick Answer -->
    <section class="bg-amber-50 border border-amber-200 rounded-2xl p-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-8 bg-amber-400 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h2 class="text-xl font-bold text-amber-900"><%=  page.quick_answer.title %></h2>
      </div>
      <p class="text-amber-800 leading-relaxed"><%=  page.quick_answer.content %></p>
    </section>

    <!-- Two-column: Confirmed + Not Verified -->
    <div class="grid md:grid-cols-2 gap-6">
      <!-- Confirmed -->
      <section class="bg-green-50 border border-green-200 rounded-2xl p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-7 h-7 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          </div>
          <h2 class="text-lg font-bold text-green-900"><%=  page.confirmed.title %></h2>
        </div>
        <ul class="space-y-2">
          <%  page.confirmed.items.forEach(function(item) { %>
          <li class="flex items-start gap-2 text-green-800 text-sm">
            <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <%=  item %>
          </li>
          <%  }); %>
        </ul>
      </section>

      <!-- Not Verified -->
      <section class="bg-red-50 border border-red-200 rounded-2xl p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-7 h-7 bg-red-500 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </div>
          <h2 class="text-lg font-bold text-red-900"><%=  page.not_verified.title %></h2>
        </div>
        <ul class="space-y-2">
          <%  page.not_verified.items.forEach(function(item) { %>
          <li class="flex items-start gap-2 text-red-800 text-sm">
            <svg class="w-4 h-4 text-red-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            <%=  item %>
          </li>
          <%  }); %>
        </ul>
      </section>
    </div>

    <!-- Official Links -->
    <section class="bg-white border border-gray-200 rounded-2xl p-8 shadow-sm">
      <h2 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
        <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
        <%=  page.official_links.title %>
      </h2>
      <div class="space-y-4">
        <%  page.official_links.items.forEach(function(link) { %>
        <a href="<%=  link.url %>" target="_blank" rel="noopener noreferrer"
           class="flex items-start gap-4 p-4 rounded-xl border border-gray-100 hover:border-indigo-300 hover:bg-indigo-50 transition-all group">
          <div class="w-8 h-8 bg-indigo-100 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-indigo-200 transition-colors">
            <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </div>
          <div>
            <p class="font-semibold text-gray-900 group-hover:text-indigo-700 transition-colors"><%=  link.label %></p>
            <p class="text-sm text-gray-500 mt-0.5"><%=  link.desc %></p>
            <p class="text-xs text-indigo-500 mt-1"><%=  link.url %></p>
          </div>
        </a>
        <%  }); %>
      </div>
    </section>

    <!-- Next Steps -->
    <section class="bg-white border border-gray-200 rounded-2xl p-8 shadow-sm">
      <h2 class="text-xl font-bold text-gray-900 mb-6"><%=  page.next_steps.title %></h2>
      <ol class="space-y-4">
        <%  page.next_steps.items.forEach(function(step, i) { %>
        <li class="flex items-start gap-4">
          <div class="w-8 h-8 bg-indigo-600 text-white rounded-full flex items-center justify-center font-bold text-sm flex-shrink-0"><%=  i + 1 %></div>
          <p class="text-gray-700 pt-1"><%=  step %></p>
        </li>
        <%  }); %>
      </ol>
    </section>

    <%- include('partials/commercial-cta', { context: 'pricing' }) %>

    <!-- FAQ -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 mb-6"><%=  page.faq.title %></h2>
      <div class="space-y-3">
        <%  page.faq.items.forEach(function(item) { %>
        <details class="bg-white rounded-xl border border-gray-200 overflow-hidden group shadow-sm">
          <summary class="flex justify-between items-center px-6 py-4 cursor-pointer font-semibold text-gray-900 hover:bg-gray-50 transition-colors list-none">
            <%=  item.q %>
            <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <div class="px-6 py-4 text-gray-600 border-t border-gray-100 leading-relaxed"><%=  item.a %></div>
        </details>
        <%  }); %>
      </div>
    </section>

    <!-- Related Developer Pages (Sibling Links) -->
    <section class="bg-slate-900 rounded-2xl p-8 text-white">
      <h2 class="text-xl font-bold mb-6"><%=  page.related.title %></h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <%  page.related.items.forEach(function(item) { %>
        <a href="<%=  link(item.slug) %>"
           class="flex items-start gap-3 p-4 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 hover:border-indigo-400/40 transition-all">
          <svg class="w-5 h-5 text-indigo-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
          <div>
            <p class="font-semibold text-white"><%=  item.title %></p>
            <p class="text-sm text-slate-400 mt-0.5"><%=  item.desc %></p>
          </div>
        </a>
        <%  }); %>
      </div>
    </section>

    <!-- Disclaimer -->
    <p class="text-xs text-gray-400 text-center border-t border-gray-200 pt-6 pb-4"><%=  page.disclaimer %></p>

  </div>
</main>
<%- include('partials/footer') %>
<script>
(function() {
  var btn = document.getElementById('mobile-menu-button');
  var menu = document.getElementById('mobile-menu');
  if (btn && menu) { btn.addEventListener('click', function() { menu.classList.toggle('hidden'); }); }
})();
</script>
</body>
</html>
